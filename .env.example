# 完整建置流程見 docs/cloudflare-setup.md
# 此檔為範本，複製成 .env 後填入實際值（.env 不進 git）

# ── R2 物件儲存（後端讀寫檔案用）──
# 建立 R2 Account Token 取得下列值：https://developers.cloudflare.com/r2/api/tokens/
ENDPOINT_URL="https://<your-account-id>.r2.cloudflarestorage.com"
AWS_ACCESS_KEY_ID="your_access_key_id"
AWS_SECRET_ACCESS_KEY="your_secret_access_key"
REGION_NAME="auto"
DEFAULT_BUCKET="ntpc-edu-bills"
DEFAULT_EXPIRES_IN=300

# ── Cloudflare AI Search（後端查詢向量索引用）──
# CF_API_TOKEN 權限需含「AI 搜尋：索引 + 執行」
# 注意：這與 AI Search 讀 R2 的「幕後權杖」是不同的兩組，別搞混（見 docs/cloudflare-setup.md）
CF_ACCOUNT_ID="your_cloudflare_account_id"
CF_AI_SEARCH_INSTANCE="edu-bills-search"
CF_API_TOKEN="your_ai_search_api_token"
# AI Search 同步用（需 AI Search Edit 權限；與 CF_API_TOKEN 不同組，僅後端用）
CF_SYNC_API_TOKEN="your_ai_search_edit_token"

# ── 登入 / 資料庫 ──
JWT_SECRET="run: openssl rand -hex 32"
DATABASE_URL="sqlite:////data/dev.db"

# ── OpenAI 網路搜尋備援（https://platform.openai.com/api-keys）──
OPENAI_API_KEY="your_openai_api_key"
OPENAI_MODEL="gpt-5-mini"
